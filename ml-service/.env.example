# Optional. Defaults to fracture_model.keras (+ fracture_model.labels.json).
# MEDAI_MODEL_FILE=medai_cnn.keras

# Horizontal-flip test-time augmentation is off by default for MRI (set to 1 to enable).
# MEDAI_MRI_TTA=0

# X-ray preprocessing for fracture models from Colab:
# - unit_range => divide pixels by 255 (matches ImageDataGenerator(rescale=1./255))
# - default => raw 0-255 float input
# MEDAI_XRAY_PREPROCESS=unit_range

# Fracture decision threshold (higher reduces false positives on healthy hands).
# MEDAI_XRAY_FRACTURE_THRESHOLD=0.75

# CT lung decision threshold (higher = fewer false positives).
# MEDAI_CT_RULE_THRESHOLD=0.75

# Ultrasound binary decision calibration:
# MEDAI_US_RULE_THRESHOLD=0.9999
# MEDAI_US_RULE_MARGIN=0.20

# CORS for FastAPI (comma-separated origins)
# CORS_ORIGINS=http://localhost:5173
